---
const base = import.meta.env.BASE_URL;
const repo = 'https://github.com/Prashanth261993/Personal-Hub';
const links = [
  { label: 'Apps', href: '#apps' },
  { label: 'Architecture', href: '#architecture' },
  { label: 'Engineering', href: '#engineering' },
  { label: 'Stack', href: '#stack' },
];
---

<header class="fixed inset-x-0 top-0 z-50">
  <nav class="glass mx-auto mt-3 flex max-w-6xl items-center justify-between rounded-2xl px-4 py-2.5 sm:px-5">
    <a href="#top" class="flex items-center gap-2.5">
      <span
        class="grid h-8 w-8 place-items-center rounded-lg bg-gradient-to-br from-[#7c7cff] to-[#22d3ee] text-sm font-bold text-[#08080c]"
        >PH</span
      >
      <span class="text-sm font-semibold tracking-tight">Personal Hub</span>
    </a>

    <div class="hidden items-center gap-1 md:flex">
      {
        links.map((l) => (
          <a
            href={l.href}
            class="rounded-lg px-3 py-1.5 text-sm text-[var(--color-muted)] transition-colors hover:text-[var(--color-ink)]"
          >
            {l.label}
          </a>
        ))
      }
    </div>

    <a
      href={repo}
      target="_blank"
      rel="noopener"
      class="inline-flex items-center gap-2 rounded-lg border border-[var(--color-border)] bg-white/5 px-3.5 py-1.5 text-sm font-medium text-[var(--color-ink)] transition-colors hover:bg-white/10"
    >
      <svg viewBox="0 0 24 24" class="h-4 w-4" fill="currentColor" aria-hidden="true">
        <path
          d="M12 .5A11.5 11.5 0 0 0 .5 12 11.5 11.5 0 0 0 8.5 23c.6.1.8-.3.8-.6v-2c-3.2.7-3.9-1.4-3.9-1.4-.5-1.3-1.3-1.7-1.3-1.7-1.1-.7 0-.7 0-.7 1.2.1 1.8 1.2 1.8 1.2 1 1.8 2.8 1.3 3.5 1 .1-.8.4-1.3.7-1.6-2.6-.3-5.3-1.3-5.3-5.7 0-1.3.5-2.3 1.2-3.1-.1-.3-.5-1.5.1-3.1 0 0 1-.3 3.3 1.2a11.5 11.5 0 0 1 6 0C17.3 4.7 18.3 5 18.3 5c.6 1.6.2 2.8.1 3.1.8.8 1.2 1.8 1.2 3.1 0 4.4-2.7 5.4-5.3 5.7.4.4.8 1.1.8 2.2v3.3c0 .3.2.7.8.6A11.5 11.5 0 0 0 23.5 12 11.5 11.5 0 0 0 12 .5Z"
        />
      </svg>
      <span class="hidden sm:inline">GitHub</span>
    </a>
  </nav>
</header>
