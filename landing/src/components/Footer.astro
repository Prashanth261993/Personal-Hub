---
const repo = 'https://github.com/Prashanth261993/Personal-Hub';
const email = 'prashanthr261993@gmail.com';
---

<footer class="relative overflow-hidden border-t border-[var(--color-border)] py-16">
  <div class="pointer-events-none absolute inset-x-0 top-0 h-40 bg-radial-glow opacity-60"></div>
  <div class="relative mx-auto max-w-6xl px-5">
    <div class="glass card-glow rounded-3xl px-8 py-12 text-center">
      <h2 class="text-2xl font-bold tracking-tight sm:text-3xl">
        Dive into the <span class="gradient-text">source</span>
      </h2>
      <p class="mx-auto mt-3 max-w-xl text-sm text-[var(--color-muted)]">
        Four apps, one monorepo, fully open. Clone it, run
        <code class="font-mono text-[var(--color-accent)]">npm run dev</code>, and explore.
      </p>
      <div class="mt-7 flex flex-wrap items-center justify-center gap-3">
        <a
          href={repo}
          target="_blank"
          rel="noopener"
          class="inline-flex items-center gap-2 rounded-xl bg-gradient-to-r from-[#7c7cff] to-[#22d3ee] px-5 py-3 text-sm font-semibold text-[#08080c] transition-transform hover:scale-[1.02]"
        >
          <svg viewBox="0 0 24 24" class="h-4 w-4" fill="currentColor" aria-hidden="true">
            <path
              d="M12 .5A11.5 11.5 0 0 0 .5 12 11.5 11.5 0 0 0 8.5 23c.6.1.8-.3.8-.6v-2c-3.2.7-3.9-1.4-3.9-1.4-.5-1.3-1.3-1.7-1.3-1.7-1.1-.7 0-.7 0-.7 1.2.1 1.8 1.2 1.8 1.2 1 1.8 2.8 1.3 3.5 1 .1-.8.4-1.3.7-1.6-2.6-.3-5.3-1.3-5.3-5.7 0-1.3.5-2.3 1.2-3.1-.1-.3-.5-1.5.1-3.1 0 0 1-.3 3.3 1.2a11.5 11.5 0 0 1 6 0C17.3 4.7 18.3 5 18.3 5c.6 1.6.2 2.8.1 3.1.8.8 1.2 1.8 1.2 3.1 0 4.4-2.7 5.4-5.3 5.7.4.4.8 1.1.8 2.2v3.3c0 .3.2.7.8.6A11.5 11.5 0 0 0 23.5 12 11.5 11.5 0 0 0 12 .5Z"
            />
          </svg>
          GitHub repository
        </a>
        <a
          href={`mailto:${email}`}
          class="inline-flex items-center gap-2 rounded-xl border border-[var(--color-border)] bg-white/5 px-5 py-3 text-sm font-semibold transition-colors hover:bg-white/10"
        >
          Contact
        </a>
      </div>
    </div>

    <div class="mt-10 flex flex-col items-center justify-between gap-3 text-xs text-[var(--color-faint)] sm:flex-row">
      <span>Personal Hub — a modular personal productivity platform.</span>
      <span>Built with Astro + Tailwind CSS · deployed on GitHub Pages.</span>
    </div>
  </div>
</footer>
