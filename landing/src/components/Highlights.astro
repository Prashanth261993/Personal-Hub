---

<section id="engineering" class="relative scroll-mt-24 py-20 sm:py-28">
  <div class="pointer-events-none absolute inset-0 bg-grid opacity-40 [mask-image:radial-gradient(60%_50%_at_50%_50%,#000,transparent)]"></div>
  <div class="relative mx-auto max-w-6xl px-5">
    <div class="reveal mx-auto max-w-2xl text-center">
      <span class="text-xs font-semibold uppercase tracking-widest text-[var(--color-accent-2)]"
        >Engineering highlights</span
      >
      <h2 class="mt-3 text-3xl font-bold tracking-tight sm:text-4xl">
        The interesting parts under the hood
      </h2>
    </div>

    <div class="mt-14 grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
      {
        highlights.map((h) => (
          <article class="reveal glass card-glow rounded-2xl p-6">
            <span class="grid h-10 w-10 place-items-center rounded-xl bg-[var(--color-accent)]/15 text-[var(--color-accent)]">
              <svg viewBox="0 0 24 24" class="h-5 w-5" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round">
                <path d={h.icon} />
              </svg>
            </span>
            <h3 class="mt-4 text-base font-semibold text-[var(--color-ink)]">{h.title}</h3>
            <p class="mt-2 text-sm leading-relaxed text-[var(--color-muted)]">{h.body}</p>
            <div class="mt-4 flex flex-wrap gap-1.5">
              {h.tags.map((t) => (
                <span class="rounded-md border border-[var(--color-border)] bg-white/[0.06] px-2 py-0.5 font-mono text-[11px] text-[var(--color-muted)]">
                  {t}
                </span>
              ))}
            </div>
          </article>
        ))
      }
    </div>
  </div>
</section>
