---
const base = import.meta.env.BASE_URL;

interface Shot {
  src: string;
  alt: string;
  caption?: string;
}

interface Props {
  id: string;
  eyebrow: string;
  title: string;
  description: string;
  features: string[];
  shots: Shot[];
  reverse?: boolean;
}

const { id, eyebrow, title, description, features, shots, reverse = false } = Astro.props;
const [primary, ...secondary] = shots;
---

<section id={id} class="relative scroll-mt-24 py-16 sm:py-24">
  <div class="mx-auto grid max-w-6xl items-center gap-10 px-5 lg:grid-cols-2 lg:gap-16">
    <!-- Copy -->
    <div class={`reveal ${reverse ? 'lg:order-2' : ''}`}>
      <span class="text-xs font-semibold uppercase tracking-widest text-[var(--color-accent-2)]"
        >{eyebrow}</span
      >
      <h2 class="mt-3 text-3xl font-bold tracking-tight sm:text-4xl">{title}</h2>
      <p class="mt-4 text-base leading-relaxed text-[var(--color-muted)]">{description}</p>

      <ul class="mt-7 space-y-3">
        {
          features.map((f) => (
            <li class="flex items-start gap-3 text-sm text-[var(--color-ink)]">
              <span class="mt-0.5 grid h-5 w-5 shrink-0 place-items-center rounded-full bg-[var(--color-accent)]/15 text-[var(--color-accent)]">
                <svg viewBox="0 0 24 24" class="h-3 w-3" fill="none" stroke="currentColor" stroke-width="3">
                  <path d="M5 13l4 4L19 7" stroke-linecap="round" stroke-linejoin="round" />
                </svg>
              </span>
              <span set:html={f} />
            </li>
          ))
        }
      </ul>
    </div>

    <!-- Visuals -->
    <div class={`reveal ${reverse ? 'lg:order-1' : ''}`}>
      <div class="window-frame card-glow rounded-[14px]">
        <div class="window-bar flex items-center gap-1.5 px-4 py-2.5">
          <span class="h-2.5 w-2.5 rounded-full bg-[#ff5f57]"></span>
          <span class="h-2.5 w-2.5 rounded-full bg-[#febc2e]"></span>
          <span class="h-2.5 w-2.5 rounded-full bg-[#28c840]"></span>
        </div>
        <img
          src={`${base}${primary.src}`}
          alt={primary.alt}
          width="1280"
          height="720"
          loading="lazy"
          data-zoom
          class="block max-h-[540px] w-full cursor-zoom-in object-cover object-top transition-[filter] duration-300 hover:brightness-110"
        />
      </div>

      {
        secondary.length > 0 && (
          <div class="mt-4 grid grid-cols-2 gap-4">
            {secondary.map((s) => (
              <figure class="window-frame overflow-hidden rounded-[12px]">
                <img
                  src={`${base}${s.src}`}
                  alt={s.alt}
                  width="640"
                  height="400"
                  loading="lazy"
                  data-zoom
                  class="block h-[150px] w-full cursor-zoom-in object-cover object-top transition-[filter] duration-300 hover:brightness-110"
                />
                {s.caption && (
                  <figcaption class="bg-[#0a0b12] px-3 py-1.5 text-[11px] text-[var(--color-faint)]">
                    {s.caption}
                  </figcaption>
                )}
              </figure>
            ))}
          </div>
        )
      }
    </div>
  </div>
</section>
